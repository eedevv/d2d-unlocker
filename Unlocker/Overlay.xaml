<Window x:Class="d2d.Overlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:d2d"
        mc:Ignorable="d"
        Title="Overlay" IsHitTestVisible="False" IsEnabled="False" ShowInTaskbar="False"
        Height="1080" Width="1920" AllowsTransparency="True" WindowStyle="None"
        Background="Transparent" Topmost="True">

    <Grid IsHitTestVisible="False" x:Name="Info" Visibility="Visible">
        <!-- Standard mode -->
        <Grid x:Name="Standard" Visibility="Visible">
            <Border x:Name="BoundingBox_Info" Background="#CC111317" CornerRadius="10" Width="200" Height="56"
                    Margin="0,0,16,16" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    IsHitTestVisible="False" BorderThickness="1" BorderBrush="#2A252B"/>
            <Border x:Name="BoundingBox_Stroke" Background="#2A111317" CornerRadius="10" Width="200" Height="56"
                    Margin="0,0,16,16" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    IsHitTestVisible="False" BorderThickness="1" BorderBrush="{StaticResource BorderAccent}"/>
            <TextBlock x:Name="FB_Text" Margin="0,0,28,32" Text="d2d" Foreground="{StaticResource TextMuted}"
                       FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" LetterSpacing="1"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom" IsHitTestVisible="False"
                       Opacity="0.7"/>
        </Grid>

        <!-- In Queue mode -->
        <Grid x:Name="InQ" Visibility="Hidden">
            <Border x:Name="BoundingBox_Info_Q" Background="#CC111317" CornerRadius="10" Width="200" Height="110"
                    Margin="0,0,16,16" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    IsHitTestVisible="False" BorderThickness="1" BorderBrush="#2A252B"/>
            <Border x:Name="BoundingBox_Stroke_Q" Background="#2A111317" CornerRadius="10" Width="200" Height="110"
                    Margin="0,0,16,16" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    IsHitTestVisible="False" BorderThickness="1" BorderBrush="{StaticResource BorderAccent}"/>
            <TextBlock x:Name="FB_Text_Q" Margin="0,0,28,86" Text="d2d" Foreground="{StaticResource TextMuted}"
                       FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" LetterSpacing="1"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom" IsHitTestVisible="False"
                       Opacity="0.5"/>
            <TextBlock x:Name="InQ_Text" Margin="0,0,28,66" Text="In Queue" Foreground="{StaticResource Warning}"
                       FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom" IsHitTestVisible="False"/>
            <TextBlock x:Name="POS_Header_Text" Margin="0,0,140,46" Text="Pos:" Foreground="{StaticResource TextDim}"
                       FontFamily="Segoe UI" FontSize="11"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom" IsHitTestVisible="False"/>
            <TextBlock x:Name="POS_Text" Margin="0,0,28,46" Text="-" Foreground="{StaticResource Text}"
                       FontFamily="Segoe UI" FontSize="11"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom" IsHitTestVisible="False"/>
            <TextBlock x:Name="ETA_Header_Text" Margin="0,0,140,30" Text="ETA:" Foreground="{StaticResource TextDim}"
                       FontFamily="Segoe UI" FontSize="11"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom" IsHitTestVisible="False"/>
            <TextBlock x:Name="ETA_Text" Margin="0,0,28,30" Text="--:--" Foreground="{StaticResource Text}"
                       FontFamily="Segoe UI" FontSize="11"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom" IsHitTestVisible="False"/>
        </Grid>

        <!-- Match Info -->
        <Grid x:Name="MatchInfo" Visibility="Hidden">
            <Border x:Name="BoundingBox_Info_M" Background="#CC111317" CornerRadius="10" Width="240" Height="96"
                    Margin="0,0,16,16" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    IsHitTestVisible="False" BorderThickness="1" BorderBrush="#2A252B"/>
            <Border x:Name="BoundingBox_Stroke_M" Background="#2A111317" CornerRadius="10" Width="240" Height="96"
                    Margin="0,0,16,16" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    IsHitTestVisible="False" BorderThickness="1" BorderBrush="{StaticResource SecondaryGlow}"/>
            <TextBlock x:Name="MatchId_Text" Margin="0,0,24,60" Text="Match: ..." Foreground="{StaticResource TextMuted}"
                       FontFamily="Segoe UI" FontSize="11"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom" IsHitTestVisible="False"/>
            <TextBlock x:Name="Region_Text" Margin="0,0,24,42" Text="Region: ..." Foreground="{StaticResource TextMuted}"
                       FontFamily="Segoe UI" FontSize="11"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom" IsHitTestVisible="False"/>
            <TextBlock x:Name="Username_Text" Margin="0,0,24,24" Text="User: ..." Foreground="{StaticResource Secondary}"
                       FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom" IsHitTestVisible="False"/>
        </Grid>

        <!-- Global info -->
        <TextBlock x:Name="VER_Header_Text" Margin="0,0,100,16" Text="Version:" Foreground="{StaticResource TextDim}"
                   FontFamily="Segoe UI" FontSize="10"
                   HorizontalAlignment="Right" VerticalAlignment="Bottom" IsHitTestVisible="False" Opacity="0.4"/>
        <TextBlock x:Name="VER_Text" Margin="0,0,16,16" Text="v3.0" Foreground="{StaticResource TextDim}"
                   FontFamily="Segoe UI" FontSize="10"
                   HorizontalAlignment="Right" VerticalAlignment="Bottom" IsHitTestVisible="False" Opacity="0.4"/>
        <TextBlock x:Name="Time_Header_Text" Margin="0,0,100,4" Text="Clock:" Foreground="{StaticResource TextDim}"
                   FontFamily="Segoe UI" FontSize="10"
                   HorizontalAlignment="Right" VerticalAlignment="Bottom" IsHitTestVisible="False" Opacity="0.4"/>
        <TextBlock x:Name="Time_Text" Margin="0,0,16,4" Text="--:--:--" Foreground="{StaticResource TextDim}"
                   FontFamily="Segoe UI" FontSize="10"
                   HorizontalAlignment="Right" VerticalAlignment="Bottom" IsHitTestVisible="False" Opacity="0.4"/>
    </Grid>
</Window>