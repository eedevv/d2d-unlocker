<Page x:Class="d2d.Cookie"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:fa="http://schemas.fontawesome.io/icons/"
      mc:Ignorable="d"
      d:DesignHeight="615" d:DesignWidth="850"
      Title="Cookie"
      Background="{StaticResource BgDark}">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="32,32,32,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,32">
            <TextBlock Text="Cookie Grabber" Style="{StaticResource SectionHeader}"/>
            <TextBlock Text="Authenticate by grabbing your session cookie" Style="{StaticResource SubText}" Margin="0,4,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <fa:ImageAwesome x:Name="Spinner" Visibility="Hidden" Foreground="{StaticResource Accent}" Icon="Refresh" Spin="True" Height="48" Width="48" Margin="0,0,0,16"/>
            <fa:ImageAwesome x:Name="Check" Visibility="Hidden" Foreground="#4CAF50" Icon="Check" Height="48" Width="48" Margin="0,0,0,16"/>
            <TextBlock x:Name="UpdateText" Text="" FontSize="18" Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" Margin="0,0,0,24"/>
            <Button x:Name="Grab_Button" Content="Grab Cookie" Style="{StaticResource ActionButton}" Width="220" Height="56" FontSize="16" Click="GrabCookie_Click" Margin="0,0,0,32"/>
        </StackPanel>

        <Border Grid.Row="2" Background="#2A3344" CornerRadius="8" Padding="16">
            <TextBox x:Name="CookieBox" TextWrapping="Wrap" PreviewKeyDown="TextBox_PreviewKeyDown" Background="Transparent" Foreground="{StaticResource TextBrush}" BorderThickness="0" FontFamily="Consolas" FontSize="12" MinHeight="80" AcceptsReturn="False">
                <TextBox.ContextMenu>
                    <ContextMenu Background="#1B1F26" Foreground="White" BorderBrush="{StaticResource BorderBrush}">
                        <MenuItem Command="ApplicationCommands.Copy" />
                    </ContextMenu>
                </TextBox.ContextMenu>
            </TextBox>
        </Border>
    </Grid>
</Page>
