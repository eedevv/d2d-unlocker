<Page x:Class="d2d.BP"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:fa="http://schemas.fontawesome.io/icons/"
      mc:Ignorable="d"
      d:DesignHeight="615" d:DesignWidth="850"
      Title="BP"
      Background="{StaticResource BgDark}">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="32,32,32,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,32">
            <TextBlock Text="Bloodpoints" Style="{StaticResource SectionHeader}"/>
            <TextBlock Text="Add bloodpoints to your account (once per account)" Style="{StaticResource SubText}" Margin="0,4,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <fa:ImageAwesome x:Name="Spinner" Visibility="Hidden" Foreground="{StaticResource Accent}" Icon="Refresh" Spin="True" Height="48" Width="48" Margin="0,0,0,16"/>
            <fa:ImageAwesome x:Name="Check" Visibility="Hidden" Foreground="#4CAF50" Icon="Check" Height="48" Width="48" Margin="0,0,0,16"/>
            <fa:ImageAwesome x:Name="Error" Visibility="Hidden" Foreground="{StaticResource Accent}" Icon="Times" Height="48" Width="48" Margin="0,0,0,16"/>
            <TextBlock x:Name="UpdateText" Text="" FontSize="16" Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" Margin="0,0,0,24"/>
            <Button x:Name="Button" Content="Add Bloodpoints" Style="{StaticResource ActionButton}" Width="220" Height="56" FontSize="16" Click="BP_AddBP" ToolTip="Bloodpoints can only be given once per account"/>
        </StackPanel>
    </Grid>
</Page>
