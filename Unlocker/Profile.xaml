<Page x:Class="d2d.Profile"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:fa="http://schemas.fontawesome.io/icons/"
      mc:Ignorable="d"
      d:DesignHeight="615" d:DesignWidth="850"
      Title="Profile"
      Background="{StaticResource BgDark}">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="32,32,32,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="Profile Editor" Style="{StaticResource SectionHeader}"/>
                <TextBlock Text="Customize your in-game profile" Style="{StaticResource SubText}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Profile Type Card -->
            <Border Grid.Row="1" Background="#2A3344" CornerRadius="8" Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Profile Type" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ProfileTypeBox" IsReadOnly="True" Text="Full Profile" Style="{StaticResource DarkTextBox}" Width="160" Margin="0,0,12,0"/>
                        <Button Grid.Column="1" x:Name="Switch" Content="Switch" Style="{StaticResource SecondaryButton}" Height="30" Width="80" Click="Switch_Profile"/>
                    </Grid>

                    <Grid x:Name="Full" Visibility="Visible" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="Item Amount" FontSize="14" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                            <TextBox x:Name="ItemAmountBox" PreviewTextInput="NumberValidationTextBox" Text="100" Style="{StaticResource DarkTextBox}" Width="120"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="Prestige Level" FontSize="14" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                            <TextBox x:Name="PrestigeLevelBox" PreviewTextInput="NumberValidationTextBox" Text="100" Style="{StaticResource DarkTextBox}" Width="120"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Per-Character Prestige Card -->
            <Border Grid.Row="2" Background="#2A3344" CornerRadius="8" Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Per-Character Prestige" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>

                    <TextBlock Text="Killers" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Accent}" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Trapper" FontSize="13" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBox x:Name="Prestige_Trapper" Grid.Row="0" Grid.Column="1" PreviewTextInput="NumberValidationTextBox" Text="0" Style="{StaticResource DarkTextBox}" Width="60" HorizontalAlignment="Left" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="1" Text="Wraith" FontSize="13" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBox x:Name="Prestige_Wraith" Grid.Row="1" Grid.Column="1" PreviewTextInput="NumberValidationTextBox" Text="0" Style="{StaticResource DarkTextBox}" Width="60" HorizontalAlignment="Left" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="2" Text="Hillbilly" FontSize="13" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBox x:Name="Prestige_Hillbilly" Grid.Row="2" Grid.Column="1" PreviewTextInput="NumberValidationTextBox" Text="0" Style="{StaticResource DarkTextBox}" Width="60" HorizontalAlignment="Left" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="3" Text="Nurse" FontSize="13" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBox x:Name="Prestige_Nurse" Grid.Row="3" Grid.Column="1" PreviewTextInput="NumberValidationTextBox" Text="0" Style="{StaticResource DarkTextBox}" Width="60" HorizontalAlignment="Left" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="4" Text="Huntress" FontSize="13" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                        <TextBox x:Name="Prestige_Huntress" Grid.Row="4" Grid.Column="1" PreviewTextInput="NumberValidationTextBox" Text="0" Style="{StaticResource DarkTextBox}" Width="60" HorizontalAlignment="Left"/>
                    </Grid>

                    <TextBlock Text="Survivors" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Accent}" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Dwight" FontSize="13" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBox x:Name="Prestige_Dwight" Grid.Row="0" Grid.Column="1" PreviewTextInput="NumberValidationTextBox" Text="0" Style="{StaticResource DarkTextBox}" Width="60" HorizontalAlignment="Left" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="1" Text="Meg" FontSize="13" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBox x:Name="Prestige_Meg" Grid.Row="1" Grid.Column="1" PreviewTextInput="NumberValidationTextBox" Text="0" Style="{StaticResource DarkTextBox}" Width="60" HorizontalAlignment="Left" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="2" Text="Claudette" FontSize="13" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBox x:Name="Prestige_Claudette" Grid.Row="2" Grid.Column="1" PreviewTextInput="NumberValidationTextBox" Text="0" Style="{StaticResource DarkTextBox}" Width="60" HorizontalAlignment="Left" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="3" Text="Jake" FontSize="13" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBox x:Name="Prestige_Jake" Grid.Row="3" Grid.Column="1" PreviewTextInput="NumberValidationTextBox" Text="0" Style="{StaticResource DarkTextBox}" Width="60" HorizontalAlignment="Left" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="4" Text="Bill" FontSize="13" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                        <TextBox x:Name="Prestige_Bill" Grid.Row="4" Grid.Column="1" PreviewTextInput="NumberValidationTextBox" Text="0" Style="{StaticResource DarkTextBox}" Width="60" HorizontalAlignment="Left"/>
                    </Grid>

                    <Button Content="Apply Per-Character Prestige" Style="{StaticResource ActionButton}" Width="240" Height="36" Click="ApplyPerCharacterPrestige" FontSize="13"/>
                </StackPanel>
            </Border>

            <!-- Extras Card -->
            <Border Grid.Row="3" Background="#2A3344" CornerRadius="8" Padding="24">
                <StackPanel>
                    <TextBlock Text="Extras" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Currency Spoof" FontSize="14" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                        <CheckBox Grid.Column="1" Click="Currency_Clicked" x:Name="CurrencySpoof" Style="{StaticResource ToggleSwitch}"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Level Spoof" FontSize="14" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                        <CheckBox Grid.Column="1" Click="Level_Clicked" x:Name="LevelSpoof" Style="{StaticResource ToggleSwitch}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
