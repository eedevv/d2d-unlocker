<Page x:Class="d2d.Profile"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:fa="http://schemas.fontawesome.io/icons/"
      mc:Ignorable="d"
      d:DesignHeight="615" d:DesignWidth="850"
      Title="Profile"
      Style="{StaticResource PageBg}">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <ScrollViewer Style="{StaticResource ScrollViewer}">
        <Grid Margin="32,32,32,32" Width="520" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,28">
                <TextBlock Text="Profile Editor" Style="{StaticResource SectionHeader}"/>
                <TextBlock Text="Customize your in-game character data" Style="{StaticResource SubText}"/>
            </StackPanel>

            <!-- Profile Type -->
            <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Profile Type" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Text}" Margin="0,0,0,16"/>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Active Profile" Style="{StaticResource Label}"/>
                            <TextBlock Text="{Binding ElementName=ProfileTypeBox, Path=Text}" Foreground="{StaticResource TextDim}" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBox x:Name="ProfileTypeBox" IsReadOnly="True" Text="Full Profile" Style="{StaticResource Input}" Width="160"/>
                            <Button Grid.Column="1" x:Name="ProfileSwitch" Content="Switch" Style="{StaticResource SecondaryButton}" Height="32" Width="80" Margin="8,0,0,0" Click="Switch_Profile"/>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="Full" Visibility="Visible">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="Item Amount" Style="{StaticResource Label}" Margin="0,0,0,8"/>
                            <TextBox x:Name="ItemAmountBox" PreviewTextInput="NumberValidationTextBox" Style="{StaticResource Input}" Width="120"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="Prestige Level" Style="{StaticResource Label}" Margin="0,0,0,8"/>
                            <TextBox x:Name="PrestigeLevelBox" PreviewTextInput="NumberValidationTextBox" Style="{StaticResource Input}" Width="120"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Per-Character Prestige -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Per-Character Prestige" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Text}" Margin="0,0,0,4"/>
                    <TextBlock Text="Set individual prestige levels for each character" Style="{StaticResource SubText}" Margin="0,0,0,20"/>

                    <TextBlock Text="Killers" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Accent}" Margin="0,0,0,8"/>
                    <Border Background="{StaticResource Surface}" CornerRadius="8" Padding="12" Margin="0,0,0,16">
                        <ScrollViewer MaxHeight="200" Style="{StaticResource ScrollViewer}">
                            <StackPanel x:Name="KillerPrestigePanel"/>
                        </ScrollViewer>
                    </Border>

                    <TextBlock Text="Survivors" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Secondary}" Margin="0,0,0,8"/>
                    <Border Background="{StaticResource Surface}" CornerRadius="8" Padding="12" Margin="0,0,0,16">
                        <ScrollViewer MaxHeight="200" Style="{StaticResource ScrollViewer}">
                            <StackPanel x:Name="SurvivorPrestigePanel"/>
                        </ScrollViewer>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                        <Button Content="Apply" Style="{StaticResource PrimaryButton}" Width="120" Height="36" Click="ApplyPerCharacterPrestige" FontSize="13" Margin="0,0,8,0"/>
                        <Button Content="Set All Max" Style="{StaticResource SecondaryButton}" Width="120" Height="36" Click="SetAllMax" FontSize="13" Margin="8,0,8,0"/>
                        <Button Content="Set Random" Style="{StaticResource GhostButton}" Width="100" Height="36" Click="SetAllRandom" FontSize="13"/>
                    </StackPanel>

                    <TextBlock x:Name="PrestigeStatus" Text="" Foreground="{StaticResource Accent}" FontSize="11" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Extras -->
            <Border Grid.Row="3" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Extras" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Text}" Margin="0,0,0,20"/>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Currency Spoof" Style="{StaticResource Label}"/>
                            <TextBlock Text="Spoof in-game currency amounts" Foreground="{StaticResource TextDim}" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" Click="Currency_Clicked" x:Name="CurrencySpoof" Style="{StaticResource ToggleSwitch}"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Level Spoof" Style="{StaticResource Label}"/>
                            <TextBlock Text="Spoof player level display" Foreground="{StaticResource TextDim}" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" Click="Level_Clicked" x:Name="LevelSpoof" Style="{StaticResource ToggleSwitch}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>