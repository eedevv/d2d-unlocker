<Page x:Class="d2d.BPTools"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:fa="http://schemas.fontawesome.io/icons/"
      mc:Ignorable="d"
      d:DesignHeight="615" d:DesignWidth="850"
      Title="BP"
      Background="{StaticResource BgDark}">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="32,32,32,32">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Bloodpoint Services" Style="{StaticResource SectionHeader}" HorizontalAlignment="Center"/>
            <TextBlock Text="Manage bloodpoints and tome progression" Style="{StaticResource SubText}" HorizontalAlignment="Center" Margin="0,4,0,32"/>

            <Border Background="#2A3344" CornerRadius="8" Padding="32" Margin="0,0,0,16" Width="400">
                <StackPanel>
                    <TextBlock Text="Bloodpoints" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="Add bloodpoints to your account" Style="{StaticResource SubText}" Margin="0,0,0,16"/>
                    <Button x:Name="BP_Button" Content="Open BP Tools" Style="{StaticResource SecondaryButton}" Height="40" Click="BP_Launch"/>
                </StackPanel>
            </Border>

            <Border Background="#2A3344" CornerRadius="8" Padding="32" Width="400" Opacity="0.5">
                <StackPanel>
                    <TextBlock Text="Tome Unlocker" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="Access the tome challenge unlocker" Style="{StaticResource SubText}" Margin="0,0,0,16"/>
                    <Button x:Name="Tome_Button" Content="Coming Soon" Style="{StaticResource SecondaryButton}" Height="40" IsEnabled="False"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>
