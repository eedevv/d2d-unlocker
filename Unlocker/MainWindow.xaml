<Window x:Class="d2d.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:d2d"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="d2d" Height="700" Width="1000" ResizeMode="CanMinimize" WindowStyle="None" AllowsTransparency="True"
        Background="Transparent">

    <Grid>
        <Border Background="{StaticResource Bg}" CornerRadius="10" Margin="0" BorderThickness="1" BorderBrush="{StaticResource Border}">
            <Grid>
                <!-- Title Bar -->
                <Border Background="{StaticResource Surface}" Height="36" VerticalAlignment="Top" CornerRadius="10,10,0,0" MouseDown="TopBar_MouseDown">
                    <Grid>
                        <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                            <Ellipse Width="10" Height="10" Fill="{StaticResource Accent}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="d2d" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,4,0">
                            <Button x:Name="MinimizeButton" Click="Minimize_Click" Width="36" Height="28" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                <TextBlock Text="&#x2014;" FontSize="12" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                            <Button x:Name="CloseButton" Click="Close_Click" Width="36" Height="28" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                <TextBlock Text="&#x2715;" FontSize="11" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Sidebar -->
                <Border Background="{StaticResource Surface}" Width="90" HorizontalAlignment="Left" Margin="0,36,0,0">
                    <StackPanel>
                        <Button x:Name="HomeButton" Style="{StaticResource SidebarButton}" Click="HomePage_Click" Tag="Active" Margin="0,4,0,0">
                            <StackPanel>
                                <fa:ImageAwesome Icon="Home" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Height="22" Width="22"/>
                                <TextBlock Text="Home" FontSize="10" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="ProfileButton" Style="{StaticResource SidebarButton}" Click="Profile_Click">
                            <StackPanel>
                                <fa:ImageAwesome Icon="Suitcase" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Height="22" Width="22"/>
                                <TextBlock Text="Profile" FontSize="10" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="SettingsButton" Style="{StaticResource SidebarButton}" Click="Settings_Click">
                            <StackPanel>
                                <fa:ImageAwesome Icon="Gear" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Height="22" Width="22"/>
                                <TextBlock Text="Settings" FontSize="10" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>

                        <Border Height="1" Background="{StaticResource Border}" Margin="16,4,16,4"/>

                        <Button x:Name="DiscordButton" Style="{StaticResource SidebarButton}" Click="GoDiscord">
                            <StackPanel>
                                <fa:ImageAwesome Icon="Comment" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Height="22" Width="22"/>
                                <TextBlock Text="Discord" FontSize="10" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="GitHubButton" Style="{StaticResource SidebarButton}" Click="GoWeb">
                            <StackPanel>
                                <fa:ImageAwesome Icon="Globe" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Height="22" Width="22"/>
                                <TextBlock Text="GitHub" FontSize="10" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Content Area -->
                <Border Background="{StaticResource Bg}" Margin="90,36,0,0" BorderThickness="1,0,0,0" BorderBrush="{StaticResource Border}">
                    <Grid>
                        <!-- Home Page -->
                        <Grid x:Name="HomeContent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,48,0,0" HorizontalAlignment="Center" VerticalAlignment="Top">
                                <TextBlock Text="d2d" FontSize="72" FontWeight="Bold" Foreground="{StaticResource Text}" HorizontalAlignment="Center" FontFamily="Segoe UI">
                                    <TextBlock.Effect>
                                        <DropShadowEffect ShadowDepth="0" Color="#E81A4A" Opacity="0.15" BlurRadius="24"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                                <TextBlock Text="Dead by Daylight Unlocker" FontSize="16" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                                    <TextBlock x:Name="VersionText" Text="d2d: v3.0" FontSize="11" Foreground="{StaticResource TextDim}" Margin="0,0,16,0"/>
                                    <TextBlock x:Name="DbdVersionText" Text="DBD: v8.5.2" FontSize="11" Foreground="{StaticResource TextDim}"/>
                                </StackPanel>
                            </StackPanel>

                            <Border Grid.Row="1" Style="{StaticResource Card}" Width="360" Height="280" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <StackPanel VerticalAlignment="Center">
                                    <fa:ImageAwesome x:Name="Spinner" Visibility="Hidden" Foreground="{StaticResource Accent}" Icon="Refresh" Spin="True" Height="40" Width="40" Margin="0,0,0,16" HorizontalAlignment="Center"/>
                                    <fa:ImageAwesome x:Name="Check" Visibility="Hidden" Foreground="{StaticResource Success}" Icon="Check" Height="40" Width="40" Margin="0,0,0,16" HorizontalAlignment="Center"/>
                                    <fa:ImageAwesome x:Name="Error" Visibility="Hidden" Foreground="{StaticResource Warning}" Icon="Times" Height="40" Width="40" Margin="0,0,0,16" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="UpdateText" Text="" FontSize="14" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,0,0,24" TextWrapping="Wrap" TextAlignment="Center"/>
                                    <Button x:Name="Launch" Content="LAUNCH GAME" Style="{StaticResource PrimaryButton}" Width="200" Height="48" FontSize="15" Click="Launch_Pressed" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                    <TextBlock Text="Click to launch and auto-authenticate" FontSize="11" Foreground="{StaticResource TextDim}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <StackPanel Grid.Row="2" Margin="0,0,0,20" HorizontalAlignment="Center" Orientation="Horizontal">
                                <Button Content="Latest Release" Style="{StaticResource GhostButton}" Click="OpenLatestRelease"/>
                            </StackPanel>
                        </Grid>

                        <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" Visibility="Collapsed"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>