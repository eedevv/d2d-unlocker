<Window x:Class="d2d.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:d2d"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="d2d" Height="650" Width="950" ResizeMode="CanMinimize" WindowStyle="None" AllowsTransparency="True">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Border Background="{StaticResource BgDark}" CornerRadius="8" Margin="0">
            <Grid>
                <!-- Title Bar -->
                <Border Background="{StaticResource BgNav}" Height="32" VerticalAlignment="Top" MouseDown="TopBar_MouseDown">
                    <Grid>
                        <TextBlock Text="d2d" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" Margin="12,0,0,0" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,4,0">
                            <Button x:Name="MinimizeButton" Click="Minimize_Click" Width="28" Height="28" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                <TextBlock Text="&#x2014;" FontSize="12" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                            <Button x:Name="CloseButton" Click="Close_Click" Width="28" Height="28" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                <TextBlock Text="&#x2715;" FontSize="11" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Sidebar -->
                <Border Background="{StaticResource BgNav}" Width="75" HorizontalAlignment="Left" Margin="0,32,0,0">
                    <StackPanel>
                        <Button Style="{StaticResource SidebarButton}" Click="HomePage_Click" Margin="0,8,0,0">
                            <StackPanel>
                                <fa:ImageAwesome Icon="Home" Foreground="{StaticResource TextMuted}" Height="22" Width="22"/>
                                <TextBlock Text="Home" Style="{StaticResource SubText}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}" Click="Cookie_Click">
                            <StackPanel>
                                <fa:ImageAwesome Icon="User" Foreground="{StaticResource TextMuted}" Height="22" Width="22"/>
                                <TextBlock Text="Cookie" Style="{StaticResource SubText}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}" Click="Tome_Click">
                            <StackPanel>
                                <fa:ImageAwesome Icon="Book" Foreground="{StaticResource TextMuted}" Height="22" Width="22"/>
                                <TextBlock Text="Tome" Style="{StaticResource SubText}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}" Click="BP_Click">
                            <StackPanel>
                                <fa:ImageAwesome Icon="Star" Foreground="{StaticResource TextMuted}" Height="22" Width="22"/>
                                <TextBlock Text="BP" Style="{StaticResource SubText}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}" Click="Profile_Click">
                            <StackPanel>
                                <fa:ImageAwesome Icon="Suitcase" Foreground="{StaticResource TextMuted}" Height="22" Width="22"/>
                                <TextBlock Text="Profile" Style="{StaticResource SubText}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}" Click="Settings_Click">
                            <StackPanel>
                                <fa:ImageAwesome Icon="Gear" Foreground="{StaticResource TextMuted}" Height="22" Width="22"/>
                                <TextBlock Text="Settings" Style="{StaticResource SubText}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}" Click="GoDiscord">
                            <StackPanel>
                                <fa:ImageAwesome Icon="Comment" Foreground="{StaticResource TextMuted}" Height="22" Width="22"/>
                                <TextBlock Text="Discord" Style="{StaticResource SubText}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}" Click="GoWeb">
                            <StackPanel>
                                <fa:ImageAwesome Icon="Globe" Foreground="{StaticResource TextMuted}" Height="22" Width="22"/>
                                <TextBlock Text="GitHub" Style="{StaticResource SubText}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Content Area -->
                <Border Background="{StaticResource BgNav}" Margin="75,32,0,0" BorderThickness="1,0,0,0" BorderBrush="#2A3344">
                    <!-- Home Content -->
                    <Grid x:Name="HomeContent">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,60,0,0" HorizontalAlignment="Center">
                            <TextBlock Text="d2d" FontSize="64" FontWeight="Bold" Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" FontFamily="Segoe UI"/>
                            <TextBlock Text="Dead by Daylight Unlocker" FontSize="20" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBlock x:Name="VersionText" Text="d2d: v2.0" FontSize="11" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,4,0,0" Opacity="0.5"/>
                            <TextBlock x:Name="DbdVersionText" Text="DBD: v7.2.3" FontSize="11" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Opacity="0.5"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <fa:ImageAwesome x:Name="Spinner" Visibility="Hidden" Foreground="{StaticResource Accent}" Icon="Refresh" Spin="True" Height="48" Width="48" Margin="0,0,0,16"/>
                            <fa:ImageAwesome x:Name="Check" Visibility="Hidden" Foreground="#4CAF50" Icon="Check" Height="48" Width="48" Margin="0,0,0,16"/>
                            <fa:ImageAwesome x:Name="Error" Visibility="Hidden" Foreground="{StaticResource Accent}" Icon="Times" Height="48" Width="48" Margin="0,0,0,16"/>
                            <TextBlock x:Name="UpdateText" Text="" FontSize="16" Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                            <Button x:Name="Launch" Content="LAUNCH" Style="{StaticResource ActionButton}" Width="220" Height="56" FontSize="18" Click="Launch_Pressed"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Margin="0,0,0,24" HorizontalAlignment="Center">
                            <Button Content="&#x1F517; Latest Release" Style="{StaticResource SecondaryButton}" Height="32" FontSize="11" Click="OpenLatestRelease" HorizontalAlignment="Center" Padding="16,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Frame for page navigation -->
                    <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" Visibility="Collapsed"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
